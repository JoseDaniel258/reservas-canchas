<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('partials/sidebar_client') %>
        
        <div class="container mt-4">
            <h2 class="mb-4">Bienvenido, <%= nombreclient %></h2>

            <div class="row">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body text-center">
                            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                                <%= usuario.nombre.charAt(0) %>
                            </div>
                            <h5><%= usuario.nombre %></h5>
                            <p class="text-muted"><%= usuario.email %></p>
                            <hr>
                            <p class="mb-0">Reservas realizadas: <strong><%= usuario.Reservas.length %></strong></p>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white fw-bold">Mis Próximas Reservas</div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Cancha</th>
                                        <th>Fecha</th>
                                        <th>Horario</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% usuario.Reservas.forEach(reserva => { %>
                                        <tr>
                                            <td><%= reserva.Horario.Cancha.nombre %></td>
                                            <td><%= reserva.Horario.fecha %></td>
                                            <td><%= reserva.Horario.hora_inicio %></td>
                                            <td>
                                                <span class="badge <%= reserva.estado === 'confirmada' ? 'bg-success' : 'bg-danger' %>">
                                                    <%= reserva.estado.toUpperCase() %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                    
                                    <% if(usuario.Reservas.length === 0) { %>
                                        <tr><td colspan="4" class="text-center py-4 text-muted">Aún no tienes reservas.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>