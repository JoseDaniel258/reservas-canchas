<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Cancha - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="d-flex">
    <%- include('./partials/sidebar') %>
    <div class="flex-grow-1 p-4 w-100">
        <h2 class="mb-4">Editar Cancha</h2>
        <div class="card shadow-sm" style="max-width: 500px;">
            <div class="card-body">
                <form action="/admin/canchas/editar/<%= cancha.id %>" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="nombre" class="form-control" value="<%= cancha.nombre %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo de Cancha</label>
                        <select name="tipo_id" class="form-select" required>
                            <% tipos.forEach(tipo => { %>
                                <option value="<%= tipo.id %>" <%= tipo.id === cancha.tipo_id ? 'selected' : '' %> >
                                    <%= tipo.nombre %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Precio por Hora ($)</label>
                        <input type="number" step="0.50" name="precio_por_hora" class="form-control" value="<%= cancha.precio_por_hora %>" required>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Actualizar Cambios</button>
                    <a href="/admin/canchas" class="btn btn-secondary w-100 mt-2">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>