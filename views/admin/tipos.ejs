<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tipos de Cancha - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="d-flex">
    <%- include('./partials/sidebar') %>

    <div class="flex-grow-1 p-4 w-100">
        <h2 class="mb-4">Gestión de Tipos de Cancha</h2>
        
        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white fw-bold">Nuevo Tipo</div>
                    <div class="card-body">
                        <form action="/admin/tipos" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Nombre de la categoría</label>
                                <input type="text" name="nombre" class="form-control" placeholder="Ej. Fútbol 5, Pádel" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Guardar</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white fw-bold">Tipos Registrados</div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Nombre</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% tipos.forEach(tipo => { %>
                                    <tr>
                                        <td><%= tipo.id %></td>
                                        <td class="fw-bold"><%= tipo.nombre %></td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-warning">Editar</button>
                                         <form action="/admin/tipos/eliminar/<%= tipo.id %>" method="POST" class="d-inline">
    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Seguro que deseas eliminar este tipo?')">Eliminar</button>
</form>
                                        </td>
                                    </tr>
                                <% }) %>
                                
                                <% if(tipos.length === 0) { %>
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted">
                                            Aún no hay tipos de cancha registrados.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>