<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canchas - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="d-flex">
    <%- include('./partials/sidebar') %>

    <div class="flex-grow-1 p-4 w-100">
        <h2 class="mb-4">Gestión de Canchas</h2>
        
        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white fw-bold">Nueva Cancha</div>
                    <div class="card-body">
                        <form action="/admin/canchas" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Nombre</label>
                                <input type="text" name="nombre" class="form-control" placeholder="Ej. Cancha Norte" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tipo de Cancha</label>
                                <select name="tipo_id" class="form-select" required>
                                    <option value="">Seleccione...</option>
                                    <% tipos.forEach(tipo => { %>
                                        <option value="<%= tipo.id %>"><%= tipo.nombre %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Precio por Hora ($)</label>
                                <input type="number" step="0.50" name="precio_por_hora" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Guardar Cancha</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white fw-bold">Canchas Existentes</div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Nombre</th>
                                    <th>Tipo</th>
                                    <th>Precio</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% canchas.forEach(cancha => { %>
                                    <tr>
                                        <td><%= cancha.id %></td>
                                        <td class="fw-bold"><%= cancha.nombre %></td>
                                        <td><%= cancha.TipoCancha ? cancha.TipoCancha.nombre : 'N/A' %></td>
                                        <td>$<%= cancha.precio_por_hora %></td>
                                        <td>
                                            <form action="/admin/canchas/eliminar/<%= cancha.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Eliminar esta cancha?')">Eliminar</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                                <% if(canchas.length === 0) { %>
                                    <tr><td colspan="5" class="text-center py-4 text-muted">Aún no hay canchas.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>